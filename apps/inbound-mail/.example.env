PORT="2525"
HOST="127.0.0.1"

IS_SELF_HOSTED=false

REDIS_DB_INDEX="2"
REDIS_HOST="localhost"
REDIS_PORT="6379"

LOG_LEVEL=info
## This value should be set to true if it is the first time you are running the with the database
MONGO_AUTO_CREATE_INDEXES=false

## S3 attachment offloading
## Inbound email attachments are uploaded to S3 before the job is enqueued so
## Redis / BullMQ only holds slim metadata instead of raw binary blobs.
##
## Required fields (leave blank to disable attachment upload — attachments will be dropped):
S3_REGION="us-east-1"
S3_BUCKET_NAME="novu-inbound-mail"
##
## Optional: point to a LocalStack / MinIO endpoint for local development
# S3_LOCAL_STACK="http://localhost:4566"
##
## Optional: CDN prefix for presigned URLs (e.g. https://cdn.example.com)
# CDN_URL=""
##
## Presigned GET URL TTL in seconds (default 604800 = 7 days, maximum allowed by S3).
## IMPORTANT: the S3 bucket lifecycle expiration for the `inbound-mail/*` prefix MUST be
## >= this value. Example bucket lifecycle rule (AWS Console / Terraform):
##   Prefix: inbound-mail/
##   Expiration: 7 days
# INBOUND_ATTACHMENT_URL_TTL_SECONDS=604800
##
## Set to true to SMTP-reject emails when any attachment fails to upload (senders retry).
## Default false: drop the failing attachment and deliver the rest.
# INBOUND_FAIL_ON_ATTACHMENT_UPLOAD_ERROR=false
