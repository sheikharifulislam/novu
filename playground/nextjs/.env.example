NEXT_PUBLIC_NOVU_BACKEND_URL=https://dev.api.novu.co
NEXT_PUBLIC_NOVU_SOCKET_URL=https://dev.ws.novu.co
NEXT_PUBLIC_NOVU_APP_ID=
NEXT_PUBLIC_NOVU_SUBSCRIBER_ID=

# Required by the Agent MCP OAuth playground (`/agents-mcp`).
# Use the same value as the dashboard's VITE_CLERK_PUBLISHABLE_KEY so a single
# Clerk session works across both apps. The Clerk SDK auto-refreshes JWTs, so
# there is no manual token paste anymore.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Agent Toolkit HITL Playground
OPENAI_API_KEY=
NOVU_SECRET_KEY=
NOVU_SUBSCRIBER_ID=
NOVU_HITL_WORKFLOW_ID=refund-approval

# Novu Chat-adapter bridge (/api/novu-agent, test UI at /novu-agent)
# Reuses NOVU_SECRET_KEY above as both the reply apiKey and the bridge HMAC secret.
NOVU_AGENT_IDENTIFIER=
# Optional — defaults to https://api.novu.co (use https://dev.api.novu.co for dev cloud)
NOVU_API_BASE_URL=
# Optional — public URL of this bridge route; when set it's registered on boot
# (use an ngrok/tunnel URL for local dev, e.g. https://<id>.ngrok-free.dev/api/novu-agent)
NOVU_BRIDGE_URL=

# /connect-chat — Slack Connect demo
# Novu integration `identifier` (slug, not _id) for the Slack integration linked to your agent
NEXT_PUBLIC_CONNECT_CHAT_INTEGRATION_IDENTIFIER=
NEXT_PUBLIC_SLACK_USER_ID=
SLACK_BOT_USER_OAUTH_TOKEN=
# Server-side fallback when /api/slack-dm-endpoint is called without integrationIdentifier in the body
NOVU_CONNECT_CHAT_INTEGRATION_IDENTIFIER=
# Workflow ID to trigger when clicking "Send Test Message" on /connect-chat
NEXT_PUBLIC_CONNECT_CHAT_TEST_WORKFLOW_ID=

# /connect-msteams — MS Teams Connect demo
NEXT_PUBLIC_CONNECT_MSTEAMS_INTEGRATION_IDENTIFIER=
# Fallback AAD Object ID used by the server-side /api/msteams-dm-endpoint route
# when no aadObjectIdOverride is passed in the request body.
# Find this in Microsoft Entra admin center or use <MsTeamsLinkUser /> delegated OAuth instead.
NEXT_PUBLIC_CONNECT_MSTEAMS_AAD_OBJECT_ID=
NOVU_CONNECT_MSTEAMS_INTEGRATION_IDENTIFIER=
# Workflow ID to trigger when clicking "Send Test Message" on /connect-msteams
NEXT_PUBLIC_CONNECT_MSTEAMS_TEST_WORKFLOW_ID=

# /connect-telegram — Telegram Connect demo
# Where the useTelegramSubscriberLink hook sends its requests:
#   /api/novu-proxy    -> live proxy that injects NOVU_SECRET_KEY (default)
#   /api/telegram-demo -> offline simulator, no bot/agent/secret required
NEXT_PUBLIC_CONNECT_TELEGRAM_API_URL=/api/novu-proxy
# Novu integration `identifier` (slug, not _id) for the Telegram integration linked to your agent
NEXT_PUBLIC_CONNECT_TELEGRAM_INTEGRATION_IDENTIFIER=

# /connect-telegram-end-user — per-user Telegram linking (Clerk auth)
NEXT_PUBLIC_CONNECT_TELEGRAM_END_USER_INTEGRATION_IDENTIFIER=

# SMTP settings for scripts/send-email.mjs
# Defaults work with a local Mailpit instance:
#   docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
#   Then open http://localhost:8025 to inspect received mail
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=test@localhost
SMTP_TO=recipient@example.com
