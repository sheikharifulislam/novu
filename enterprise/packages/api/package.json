{
  "name": "@novu/ee-api",
  "version": "2.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "node ./check-ee.mjs",
    "build:esm": "node_modules/.bin/tsc -p tsconfig.json",
    "build:watch": "node_modules/.bin/tsc -w -p tsconfig.json",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "echo 'skip lint in the ci'",
    "test": "mocha --require ts-node/register --extension ts 'src/**/*.spec.ts'"
  },
  "dependencies": {
    "@novu/application-generic": "workspace:*",
    "@novu/dal": "workspace:*",
    "@nestjs/swagger": "7.4.0",
    "@novu/shared": "workspace:*",
    "@novu/stateless": "workspace:*",
    "@types/express": "4.17.17",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "@novu/testing": "workspace:*",
    "express": "^5.0.1",
    "sns-validator": "^0.3.5"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.24",
    "@types/chai": "^4.2.11",
    "@types/mocha": "^10.0.8",
    "@types/node": "^22.0.0",
    "@types/sinon": "^9.0.0",
    "@types/sns-validator": "^0.3.3",
    "chai": "^4.2.0",
    "mocha": "^10.2.0",
    "rxjs": "7.8.2",
    "sinon": "^9.2.4",
    "ts-node": "~10.9.1",
    "typescript": "5.6.2"
  },
  "peerDependencies": {
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24"
  }
}
