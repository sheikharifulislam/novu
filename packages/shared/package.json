{
  "name": "@novu/shared",
  "version": "2.8.0",
  "description": "",
  "scripts": {
    "start": "npm run start:dev",
    "afterinstall": "pnpm build",
    "prebuild": "rimraf dist",
    "build": "npm run build:cjs && npm run build:esm",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.json",
    "build:watch": "cross-env node_modules/.bin/tsc -p tsconfig.json -w --preserveWatchOutput",
    "postbuild": "npm run check:circulars",
    "start:dev": "pnpm build:watch",
    "precommit": "lint-staged",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest",
    "watch:test": "pnpm test --watch",
    "check:circulars": "madge --circular --extensions ts ./src"
  },
  "author": "",
  "license": "ISC",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "files": [
    "dist/",
    "docs/agent-onboarding.md",
    "!**/*.spec.*",
    "!**/*.json",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.js"
    },
    "./utils": {
      "require": "./dist/cjs/utils/index.js",
      "import": "./dist/esm/utils/index.js",
      "types": "./dist/esm/utils/index.d.js"
    },
    "./utils/private-ip-classification": {
      "require": "./dist/cjs/utils/private-ip-classification.js",
      "import": "./dist/esm/utils/private-ip-classification.js",
      "types": "./dist/esm/utils/private-ip-classification.d.ts"
    },
    "./utils/outbound-ssrf-allow-list": {
      "require": "./dist/cjs/utils/outbound-ssrf-allow-list.js",
      "import": "./dist/esm/utils/outbound-ssrf-allow-list.js",
      "types": "./dist/esm/utils/outbound-ssrf-allow-list.d.ts"
    },
    "./utils/ssrf-url-validation": {
      "require": "./dist/cjs/utils/ssrf-url-validation.js",
      "import": "./dist/esm/utils/ssrf-url-validation.js",
      "types": "./dist/esm/utils/ssrf-url-validation.d.ts"
    },
    "./utils/safe-outbound-http": {
      "require": "./dist/cjs/utils/safe-outbound-http.js",
      "import": "./dist/esm/utils/safe-outbound-http.js",
      "types": "./dist/esm/utils/safe-outbound-http.d.ts"
    },
    "./docs/agent-onboarding.md": "./docs/agent-onboarding.md"
  },
  "dependencies": {
    "lru-cache": "^11.5.1"
  },
  "devDependencies": {
    "madge": "^8.0.0",
    "rimraf": "^3.0.2",
    "typescript": "5.6.2",
    "vitest": "^2.1.9"
  },
  "nx": {
    "tags": [
      "type:package"
    ]
  }
}
